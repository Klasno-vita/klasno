{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Validate: foundation",
      "type": "shell",
      "command": "$ErrorActionPreference = 'Stop'; docker compose -f docker-compose.yml config --quiet; & \"${config:python.defaultInterpreterPath}\" -c \"import pathlib, tomllib; tomllib.loads(pathlib.Path('pyproject.toml').read_text())\"",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "powershell.exe",
          "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-Command"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Docker: compose config",
      "type": "shell",
      "command": "docker compose -f docker-compose.yml config --quiet",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "powershell.exe",
          "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-Command"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Python: lint",
      "type": "shell",
      "command": "& \"${config:python.defaultInterpreterPath}\" -m ruff check .",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "powershell.exe",
          "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-Command"]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Python: test",
      "type": "shell",
      "command": "& \"${config:python.defaultInterpreterPath}\" -m pytest",
      "options": {
        "cwd": "${workspaceFolder}",
        "shell": {
          "executable": "powershell.exe",
          "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-Command"]
        }
      },
      "group": "test",
      "problemMatcher": []
    }
  ]
}
